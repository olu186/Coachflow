# Supabase (required for both web and mobile)
# Create a project at https://supabase.com and copy these from Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Mobile (Expo) can use the same vars or override with EXPO_PUBLIC_* for app-specific config
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Web app URL (for invite validate/accept). Use tunnel (e.g. ngrok) or production URL when testing mobile invite.
# EXPO_PUBLIC_WEB_APP_URL=https://your-app.vercel.app

# Optional: for server-only operations (e.g. invite validation by token). Keep secret.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Web app public URL (for invite links in emails). Set to your deployed URL (e.g. https://coachflow.vercel.app) so invite links open the /invite page and then the mobile app. Without this, invite links use coachflow:// and may not open from email.
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Optional: Resend (client invite emails). Get key at https://resend.com
# Without this, invite link is still created; trainer must copy and share it manually.
# RESEND_API_KEY=re_...
# From address (optional). Default: CoachFlow <onboarding@resend.dev>. For production, verify a domain in Resend and set e.g. invites@yourdomain.com
# RESEND_FROM_EMAIL=CoachFlow <invites@yourdomain.com>

# Optional: Stripe (Phase 6 — trainer subscription)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
