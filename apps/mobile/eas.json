{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": true },
      "android": { "buildType": "apk" },
      "env": { "NPM_CONFIG_IGNORE_SCRIPTS": "true" }
    },
    "preview": {
      "distribution": "internal",
      "ios": { "simulator": false },
      "android": { "buildType": "apk" },
      "env": { "NPM_CONFIG_IGNORE_SCRIPTS": "true" }
    },
    "production": {
      "ios": {},
      "android": {},
      "env": { "NPM_CONFIG_IGNORE_SCRIPTS": "true" }
    }
  }
}
